[Unit]
Description=Aspirant contact form backend (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/aspirant-backend
EnvironmentFile=/opt/aspirant-backend/.env
ExecStart=/opt/aspirant-backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
